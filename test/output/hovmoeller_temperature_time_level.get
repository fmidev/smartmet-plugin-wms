<style type="text/css"><![CDATA[

/* Temperature across all pressure levels – red (warm, low levels) → blue (cold, upper levels) */
.TLev_30_inf  { stroke:none; fill: rgb(180,0,0)   }
.TLev_25_30   { stroke:none; fill: rgb(220,30,0)   }
.TLev_20_25   { stroke:none; fill: rgb(255,80,0)   }
