.TLev_40_35   { stroke:none; fill: rgb(0,10,140)    }
.TLev_45_40   { stroke:none; fill: rgb(30,0,120)    }
.TLev_50_45   { stroke:none; fill: rgb(70,0,100)    }
.TLev_inf_50  { stroke:none; fill: rgb(110,0,80)    }

 ]]>
</style>


