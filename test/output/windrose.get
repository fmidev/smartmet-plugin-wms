<svg width="800" height="800" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink">
<title>Wind roses</title>
<defs>
<style type="text/css"><![CDATA[

.StationMarker	{ fill: none; stroke: black; stroke-width: 0.2px }
.StationName	{ fill: black; font-family: Roboto; font-size: 11; text-decoration: underline }
.WindRose	{ fill: none; stroke: black; stroke-width: 0.2px; stroke-dasharray: 3,3 }
.RoseConnector	{ stroke: black; stroke-width: 0.2px; stroke-dasharray: 2,2 }
.LightWind	{ fill: green; stroke: black; stroke-width: 0.5px }
.ModerateWind	{ fill: yellow; stroke: black; stroke-width: 0.5px }
.HeavyWind	{ fill: red; stroke: black; stroke-width: 0.5px }
.RoseTemperature	{ fill: black; font-family: Roboto; font-size: 10 }
.RoseMeanWind		{ fill: black; font-family: Roboto; font-size: 10; font-weight: bold; letter-spacing: -0.03em }
.RoseMaxWind		{ fill: black; font-family: Roboto; font-size: 10 }
.RoseLegendText		{ stroke: none; fill: black; text-anchor: end; font-family: Roboto; font-size: 10 }
 ]]>
</style>
<symbol id="station" overflow="visible">
  <desc>Station marker</desc>
  <circle cx="0" cy="0" r="2"/>
</symbol>
<symbol id="windrose" overflow="visible">
  <desc>Wind rose</desc>
  <circle cx="0" cy="0" r="20"/>
</symbol>
<symbol id="windroselegend" overflow="visible">
  <desc>Wind Rose Legend</desc>
  <rect fill="white" width="220" height="60" style="stroke:black; stroke-width:1px" x="-85" y="-30"/>
  <use class="WindRose" x="0" y="0" xlink:href="#windrose"/>
  <path class="HeavyWind" d="M0 0 -19,-8 A 20 20 0,0,1 -8,-19Z"/>
  <path class="ModerateWind" d="M0 0 -19,7 A 19 19 0,0,1 -19,-8Z"/>
  <path class="LightWind" d="M0 0 -8,18 A 15 15 0,0,1 -19,7Z"/>
  <text class="RoseTemperature" x="25" y="16">mean temperature</text>
  <text class="RoseMeanWind" x="25" y="3">mean wind</text>
  <text class="RoseMaxWind" x="25" y="-10">max wind</text>
  <text class="RoseLegendText" x="-25" y="-10">&#x2265;14 m/s</text>
  <text class="RoseLegendText" x="-25" y="5">8-14 m/s</text>
  <text class="RoseLegendText" x="-25" y="20">&lt;8 m/s</text>
</symbol>

