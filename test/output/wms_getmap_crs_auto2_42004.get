<style type="text/css"><![CDATA[
 .Alandcity { fill:rgb(255,0,0); stroke:rgb(0,0,0); stroke-width:0.5; } .BigCity { fill:rgb(255,0,0); stroke:rgb(0,0,0); stroke-width:0.5; } .City { fill:rgb(192,0,0); stroke:rgb(0,0,0); stroke-width:0.5; }
