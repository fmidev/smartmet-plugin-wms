.Precipitation_3_4	{ stroke:none; fill: rgb(255,135,20) }
.Precipitation_4_5	{ stroke:none; fill: rgb(230,90,0) }
.Precipitation_5_inf	{ stroke:none; fill: rgb(235,0,0) }
.Finland	{ stroke: none; fill: rgb(230,238,166) }
.Europe		{ stroke: none; fill: rgb(198,198,198) }
.Lake		{ stroke: none; fill: rgb(122,190,242) }
.Sea		{ stroke: none; fill: rgb(190,230,255) }
.Borders	{ fill: none; stroke: black; stroke-width: 0.5 }
.Road		{ fill: none; stroke: rgb(150,150,150); stroke-width: 0.6 }

