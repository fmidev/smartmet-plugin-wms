<path d="M-1,1 l2,-2 M0,10 l10,-10 M9,11 l2,-2" style="stroke:black; stroke-width:0.7"/>
</pattern-->
<pattern id="fast_ice" patternUnits="userSpaceOnUse" width="8" height="8">
<path d="M-1,1 l2,-2 M0,8 l8,-8 M7,9 l2,-2" style="stroke:black; stroke-width:0.7"/>
</pattern>
