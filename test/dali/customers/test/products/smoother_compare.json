{
  "width": 1610,
  "height": 350,
  "title": "Grid smoothers at equal scale (matched to Savitzky-Golay 7x7)",
  "producer": "pal_skandinavia",
  "projection": {
    "crs": "data",
    "xsize": 310,
    "ysize": 310
  },
  "views": [
    {
      "qid": "v_orig",
      "attributes": {
        "transform": "translate(10,30)"
      },
      "layers": [
        {
          "qid": "b_orig",
          "layer_type": "isoband",
          "isobands": "json:isobands/temperature.json",
          "css": "isobands/temperature.css",
          "parameter": "Temperature"
        },
        {
          "qid": "l_orig",
          "layer_type": "isoline",
          "isolines": "json:isolines/temperature.json",
          "css": "isolines/temperature.css",
          "parameter": "Temperature",
          "attributes": {
            "class": "Temperature"
          }
        },
        {
          "qid": "t_orig",
          "tag": "text",
          "cdata": "original",
          "attributes": {
            "x": 0,
            "y": -8,
            "font-family": "Roboto",
            "font-weight": "bold",
            "font-size": 14,
            "fill": "black"
          }
        }
      ]
    },
    {
      "qid": "v_sg",
      "attributes": {
        "transform": "translate(330,30)"
      },
      "layers": [
        {
          "qid": "b_sg",
          "layer_type": "isoband",
          "isobands": "json:isobands/temperature.json",
          "css": "isobands/temperature.css",
          "parameter": "Temperature",
          "smoother": {
            "size": 3,
            "degree": 2
          }
        },
        {
          "qid": "l_sg",
          "layer_type": "isoline",
          "isolines": "json:isolines/temperature.json",
          "css": "isolines/temperature.css",
          "parameter": "Temperature",
          "attributes": {
            "class": "Temperature"
          },
          "smoother": {
            "size": 3,
            "degree": 2
          }
        },
        {
          "qid": "t_sg",
          "tag": "text",
          "cdata": "Savitzky-Golay 7x7",
          "attributes": {
            "x": 0,
            "y": -8,
            "font-family": "Roboto",
            "font-weight": "bold",
            "font-size": 14,
            "fill": "black"
          }
        }
      ]
    },
    {
