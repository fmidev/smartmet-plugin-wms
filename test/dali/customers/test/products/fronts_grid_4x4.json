{
    "title": "Weather fronts – 4x4 continuity demo (48h at 3h steps)",
    "producer": "ecmwf_skandinavia_painepinta",
    "width": 1250,
    "height": 850,

    "projection":
    {
        "xsize": 300,
        "ysize": 200,
        "crs": "EPSG:3857",
        "bboxcrs": "WGS84",
        "x1": -10,
        "y1": 45,
        "x2": 45,
        "y2": 70
    },

    "views": [
        {
            "qid": "v",
            "layers": [
                {
                    "layer_type": "background",
                    "attributes": { "fill": "rgb(190,230,255)" }
                },
                {
                    "layer_type": "map",
                    "map":
                    {
                        "schema": "natural_earth",
                        "table": "admin_0_countries",
                        "minarea": 50
                    },
                    "attributes": { "fill": "rgb(220,220,210)", "stroke": "none" }
                },
                {
                    "layer_type": "map",
                    "map":
                    {
                        "lines": true,
                        "schema": "natural_earth",
                        "table": "admin_0_countries",
                        "minarea": 50
                    },
                    "attributes": { "fill": "none", "stroke": "#555", "stroke-width": "0.4px" }
                },
                {
                    "layer_type": "fronts",
                    "css": "fronts/fronts.css",
                    "front_source": "grid",
                    "grid":
                    {
                        "level": 850,
                        "min_gradient": 2e-6,
                        "min_length_px": 30,
                        "temporal_smoothing":
                        {
                            "offsets_minutes": [-180, 0, 180],
                            "weights": [0.25, 0.5, 0.25]
                        }
                    },
                    "radius": 2,
                    "iterations": 2,
                    "bezier": 2.0
                },
                {
                    "layer_type": "time",
                    "timestamp": "validtime",
                    "timezone": "UTC",
                    "format": "%m-%d %H UTC",
                    "x": 6,
                    "y": 16,
                    "attributes":
                    {
                        "font-family": "Roboto",
                        "font-weight": "bold",
                        "font-size": 11
                    }
                }
            ],
            "repeat": [
                { "time_offset":    0, "attributes": { "transform": "translate(10,10)" } },
                { "time_offset":  180, "attributes": { "transform": "translate(320,10)" } },
                { "time_offset":  360, "attributes": { "transform": "translate(630,10)" } },
                { "time_offset":  540, "attributes": { "transform": "translate(940,10)" } },
                { "time_offset":  720, "attributes": { "transform": "translate(10,220)" } },
                { "time_offset":  900, "attributes": { "transform": "translate(320,220)" } },
                { "time_offset": 1080, "attributes": { "transform": "translate(630,220)" } },
                { "time_offset": 1260, "attributes": { "transform": "translate(940,220)" } },
                { "time_offset": 1440, "attributes": { "transform": "translate(10,430)" } },
                { "time_offset": 1620, "attributes": { "transform": "translate(320,430)" } },
                { "time_offset": 1800, "attributes": { "transform": "translate(630,430)" } },
                { "time_offset": 1980, "attributes": { "transform": "translate(940,430)" } },
                { "time_offset": 2160, "attributes": { "transform": "translate(10,640)" } },
                { "time_offset": 2340, "attributes": { "transform": "translate(320,640)" } },
                { "time_offset": 2520, "attributes": { "transform": "translate(630,640)" } },
                { "time_offset": 2700, "attributes": { "transform": "translate(940,640)" } }
            ]
        }
    ]
}
