{
    "title": "TFP diagnostic – PotentialTemperature 850 hPa",
    "producer": "ecmwf_skandinavia_painepinta",

    "projection":
    {
        "xsize": 700,
        "ysize": 500,
        "crs": "EPSG:3857",
        "bboxcrs": "WGS84",
        "x1": -10,
        "y1": 45,
        "x2": 45,
        "y2": 70
    },

    "views": [
        {
            "qid": "v1",
            "layers": [
                {
                    "layer_type": "background",
                    "attributes": { "fill": "rgb(240,240,240)" }
                },
                {
                    "qid": "tfp",
                    "layer_type": "isoband",
                    "parameter": "TFP",
                    "level": 850,
                    "tfp":
                    {
                        "field": "PotentialTemperature",
                        "smoothing_passes": 3
                    },
                    "css": "isobands/tfp.css",
                    "isobands": "json:isobands/tfp.json"
                },
                {
                    "qid": "borders",
                    "layer_type": "map",
                    "map":
                    {
                        "lines": true,
                        "schema": "natural_earth",
                        "table": "admin_0_countries",
                        "minarea": 50
                    },
                    "attributes": { "fill": "none", "stroke": "#333", "stroke-width": "0.5px" }
                },
                {
                    "qid": "t1",
                    "layer_type": "time",
                    "timestamp": "validtime",
                    "timezone": "UTC",
                    "format": "%Y-%m-%d %H:%M UTC",
                    "x": 10,
                    "y": 20,
                    "attributes":
                    {
                        "font-family": "Roboto",
                        "font-weight": "bold",
                        "font-size": 14
                    }
                }
            ]
        }
    ]
}
