{
    "title": "Weather fronts – TFP detection on ecpainepinta 850 hPa",
    "producer": "ecmwf_skandinavia_painepinta",

    "projection":
    {
        "xsize": 700,
        "ysize": 500,
        "crs": "EPSG:3857",
        "bboxcrs": "WGS84",
        "x1": -10,
        "y1": 45,
        "x2": 45,
        "y2": 70
    },

    "views": [
        {
            "qid": "v1",
            "layers": [
                {
                    "layer_type": "background",
                    "attributes": { "fill": "rgb(190,230,255)" }
                },
                {
                    "qid": "land",
                    "layer_type": "map",
                    "map":
                    {
                        "schema": "natural_earth",
                        "table": "admin_0_countries",
                        "minarea": 50
                    },
                    "attributes": { "fill": "rgb(220,220,210)", "stroke": "none" }
                },
                {
                    "qid": "borders",
                    "layer_type": "map",
                    "map":
                    {
                        "lines": true,
                        "schema": "natural_earth",
                        "table": "admin_0_countries",
                        "minarea": 50
                    },
                    "attributes": { "fill": "none", "stroke": "#555", "stroke-width": "0.5px" }
                },
                {
                    "qid": "wf",
                    "layer_type": "fronts",
                    "css": "fronts/fronts.css",
                    "source": "grid",
                    "grid":
                    {
                        "level": 850,
                        "min_gradient": 2e-6,
                        "min_length_px": 40,
                        "temporal_smoothing":
                        {
                            "offsets_minutes": [-180, 0, 180],
                            "weights": [0.25, 0.5, 0.25]
                        }
                    },
                    "radius": 2,
                    "iterations": 2,
                    "bezier": 2.0
                },
                {
                    "qid": "t1",
                    "layer_type": "time",
                    "timestamp": "validtime",
                    "timezone": "UTC",
                    "format": "%Y-%m-%d %H:%M UTC",
                    "x": 10,
                    "y": 20,
                    "attributes":
                    {
                        "font-family": "Roboto",
                        "font-weight": "bold",
                        "font-size": 14
                    }
                }
            ]
        }
    ]
}
