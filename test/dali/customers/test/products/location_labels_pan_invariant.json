{
    "title": "LocationLayer — greedy label placement with pan-invariant filter",

    // Center on Jyväskylä, ~1.5× more zoomed than the SA test, so that
    // there are labels right at the edges and beyond.  This is what
    // exercises pan-invariance: a city near or just beyond the visible
    // edge is in the buffered set but not the visible bbox, and its
    // presence influences the visible cities' placement decisions.  A
    // sparse-edge view would not test the property at all.
    "projection":
    {
        "xsize": 600,
        "ysize": 600,
        "crs": "EPSG:3067",
        "bboxcrs": "EPSG:4326",
        "cy": 62.24,
        "cx": 25.75,
        "resolution": 0.67
    },

    "defs":
    {
        "layers":
        [
            {
                "tag": "symbol",
                "attributes": { "id": "dot", "overflow": "visible" },
                "layers":
                [
                    {
                        "tag": "circle",
                        "attributes": { "r": "3", "cx": "0", "cy": "0" }
                    }
                ]
            }
        ]
    },

    "views":
    [
        {
            "qid": "v1",
            "layers":
            [
                {
                    "qid": "background",
                    "layer_type": "map",
                    "map":
                    {
                        "schema": "natural_earth",
                        "table": "admin_0_countries",
                        "minarea": 10
                    },
                    "attributes":
                    {
                        "fill": "#e8e8e8",
                        "stroke": "#aaa",
                        "stroke-width": "0.5"
                    }
                },
                {
                    "qid": "cities",
                    "layer_type": "location",
                    "keyword": "municipalities_fi",
                    "countries": "fi",
                    "mindistance": 30,
                    // Pan-invariant placement: candidates are filtered
                    // through a margin-extended bbox before projection
                    // and placement, then the visible-bbox check happens
                    // at render time.  This makes label decisions stable
                    // when the bbox is shifted by less than `margin`
                    // pixels — necessary for tile rendering and for
                    // viewer software that pans by issuing successive
                    // GetMap requests.
                    "pan_invariant": true,
                    "symbols":
                    {
                        "default":
                        [
                            { "hilimit": 100000, "symbol": "dot" },
                            { "lolimit": 100000, "symbol": "dot" }
                        ]
                    },
                    "attributes":
                    {
                        "fill": "#c00000",
                        "stroke": "none"
                    },
                    // Greedy placement in geonames priority order (highest-priority
                    // cities placed first, dropping labels with no valid position).
                    // k=8 tries the 8 Imhof positions; the first non-overlapping
                    // one that fits within the map bounds is chosen.
                    "label":
                    {
                        "algorithm": "greedy",
                        "candidates": 8,
                        "offset": 0,
                        "symbol_size": 6,
                        "font_family": "sans-serif",
                        "font_size": 10,
                        "fill": "#222222",
                        "stroke": "white",
                        "stroke_width": 2.5,
                        "stroke_opacity": 0.8,
                        "max_labels": 120,
                        // Style overrides by population: large cities get bigger,
                        // bolder labels so they read as more important than small
                        // municipalities.  The location label is context for weather
                        // data, so keep it lighter than the weather symbology.
                        "classes":
                        [
                            {
                                "lolimit": 200000,
                                "font_size": 13,
                                "font_weight": "bold",
                                "fill": "#111111"
                            },
                            {
                                "lolimit": 50000,
                                "font_size": 11
                            }
                        ]
                    }
                }
            ]
        }
    ]
}
